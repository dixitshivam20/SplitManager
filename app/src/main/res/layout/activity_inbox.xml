<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Action bar row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_mark_all_read"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:text="Mark all read"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_clear_inbox"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear all"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_empty_inbox"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No payments detected yet.\nPayments will appear here automatically."
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        android:padding="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_inbox"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to split · Long press to remove"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingBottom="12dp"/>

</LinearLayout>
